class Solution {
public:
    vector<int> twoSum(vector<int>& nums, int target) {
        unordered_map<int, int> mp;

        for (int i = 0; i < nums.size(); i++) {      #0(n)_LIST
            int MORE = target - nums[i];

            if (mp.find(MORE) != mp.end()) {
                return {mp[MORE], i};        #RETURN_INDEX
            }

            mp[nums[i]] = i;
        }

        return {};
    }
};
