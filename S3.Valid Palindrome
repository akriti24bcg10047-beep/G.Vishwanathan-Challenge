class Solution {
public:
    bool isPalindrome(string s) {
        int left = 0;
        int right = s.size() - 1;

        while (left < right) {
            while (left < right && !isValid(s[left])) left++;
            while (left < right && !isValid(s[right])) right--;

            char l = toLower(s[left]);
            char r = toLower(s[right]);

            if (l != r) return false;

            left++;
            right--;
        }

        return true;
    }

    bool isValid(char c) {
        return (c >= 'a' && c <= 'z') ||
               (c >= 'A' && c <= 'Z') ||
               (c >= '0' && c <= '9');
    }

    char toLower(char c) {
        if (c >= 'A' && c <= 'Z')
            return c + 32;
        return c;
    }
};
